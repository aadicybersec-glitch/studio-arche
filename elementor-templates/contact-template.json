              },
              "elements": []
            },
            {
              "id": "0aa856c2",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Let us craft your space.",
                "header_size": "h1",
                "align": "left",
                "css_classes": "arche-reveal-text"
              },
              "elements": []
            },
            {
              "id": "3422105a",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "We accept a limited number of residential and commercial commissions annually. Please outline your physical site coordinates, project scope, and aesthetic ambitions, and our directors will initiate contact.",
                "css_classes": "arche-lead arche-reveal-text"
              },
              "elements": []
            }
          ]
        },
        {
          "id": "4c8ae873",
          "elType": "container",
          "settings": {
            "content_width": "full",
            "flex_direction": "column",
            "flex_justify_content": "flex-start",
            "flex_align_items": "stretch",
            "width": {
              "unit": "%",
              "size": 55
            }
          },
          "elements": [
            {
              "id": "423fcfe2",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "\n<div class=\"arche-form\" style=\"margin-top: 2rem;\">\n    <form action=\"#\" method=\"POST\" id=\"arche-commission-form\" onsubmit=\"event.preventDefault(); alert('Commission Inquiry Submitted Successfully. Our curators will contact you within 48 hours.');\">\n        <div style=\"display: flex; gap: 30px; margin-bottom: 2rem;\">\n            <div style=\"flex: 1;\">\n                <label class=\"arche-subtitle-caps\" style=\"font-size: 0.6rem; display: block; margin-bottom: 5px;\">01 / Full Name</label>\n                <input type=\"text\" name=\"client_name\" placeholder=\"E.g., Julian Vane\" required>\n            </div>\n            <div style=\"flex: 1;\">\n                <label class=\"arche-subtitle-caps\" style=\"font-size: 0.6rem; display: block; margin-bottom: 5px;\">02 / Email Address</label>\n                <input type=\"email\" name=\"client_email\" placeholder=\"E.g., julian@vane.com\" required>\n            </div>\n        </div>\n        <div style=\"display: flex; gap: 30px; margin-bottom: 2rem;\">\n            <div style=\"flex: 1;\">\n                <label class=\"arche-subtitle-caps\" style=\"font-size: 0.6rem; display: block; margin-bottom: 5px;\">03 / Project Typology</label>\n                <input type=\"text\" name=\"project_type\" placeholder=\"E.g., Private Villa / Boutique Retail\">\n            </div>\n            <div style=\"flex: 1;\">\n                <label class=\"arche-subtitle-caps\" style=\"font-size: 0.6rem; display: block; margin-bottom: 5px;\">04 / Site Location</label>\n                <input type=\"text\" name=\"project_location\" placeholder=\"E.g., Geneva, Switzerland\">\n            </div>\n        </div>\n        <div style=\"margin-bottom: 2.5rem;\">\n            <label class=\"arche-subtitle-caps\" style=\"font-size: 0.6rem; display: block; margin-bottom: 5px;\">05 / Spatial Ambitions</label>\n            <textarea name=\"spatial_description\" placeholder=\"Describe the physical dimensions and emotional tone of the volume...\" required></textarea>\n        </div>\n        <div>\n            <button type=\"submit\" class=\"arche-btn-outline\" style=\"border-color: var(--arche-obsidian); padding: 1.2rem 3rem;\">\n                Submit Commission Inquiry\n            </button>\n        </div>\n    </form>\n</div>\n"
              },
              "elements": []
            }
          ]
        }
      ]
    },
